{
    "categorizeByGroup": true,
    "categoryOrder": [
        "Types",
        "Validators",
        "Enhanced Validators",
        "DNSSEC Validators",
        "Utilities",
        "Performance",
        "Errors"
    ],
    "entryPoints": ["./src"],
    "exclude": [
        "**/*.test.ts",
        "**/*.spec.ts",
        "**/tests/**/*"
    ],
    "excludeExternals": true,
    "excludePrivate": true,
    "excludeProtected": true,
    "gitRevision": "main",
    "hideBreadcrumbs": true,
    "hidePageHeader": true,
    "logLevel": "Warn",
    "name": "DNS Validator",
    "out": "docs",
    "plugin": ["typedoc-plugin-markdown"],
    "readme": "README.md",
    "sort": ["source-order"],
    "theme": "markdown",
    "treatWarningsAsErrors": true,
    "validation": {
        "invalidLink": true,
        "notDocumented": false,
        "notExported": true
    }
}
